{
  "name": "readshell",
  "version": "0.2.5",
  "description": "终端内低打断轻阅读工具 · CLI Light Reading Tool for Developers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "novel": "bin/readshell.js",
    "readshell": "bin/readshell.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch --onSuccess 'node dist/index.js'",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "keywords": [
    "cli",
    "terminal",
    "reader",
    "tui",
    "novel",
    "ebook",
    "epub",
    "txt",
    "reading"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chardet": "^2.0.0",
    "conf": "^13.0.0",
    "epub2": "^3.0.2",
    "html-to-text": "^9.0.5",
    "iconv-lite": "^0.6.3",
    "ink": "^5.1.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/html-to-text": "^9.0.4",
    "@types/react": "^18.3.12",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
